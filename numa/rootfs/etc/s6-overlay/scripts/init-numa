#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Numa add-on: init-numa
# Reads add-on options, generates /config/numa.toml (when config_source=default),
# and checks network readiness before Numa starts.
# Called from /etc/s6-overlay/s6-rc.d/init-numa/up (execlineb single-line).
#
# Scalar fields are read via bashio::config.
# Array fields are read via jq directly from /data/options.json — bashio::config
# on an array key returns one item per line (for iteration), not a JSON array,
# which is not valid TOML syntax.
# ==============================================================================
set -euo pipefail

declare log_level
declare rust_log_level
declare config_source

# ------------------------------------------------------------------------------
# Log level + RUST_LOG
# ------------------------------------------------------------------------------
log_level=$(bashio::config 'log_level' 'info')
bashio::log.level "${log_level}"

case "${log_level}" in
  notice)  rust_log_level="info"  ;;
  warning) rust_log_level="warn"  ;;
  fatal)   rust_log_level="error" ;;
  *)       rust_log_level="${log_level}" ;;
esac
printf "%s" "${rust_log_level}" > /var/run/s6/container_environment/RUST_LOG

bashio::log.info "Initialising Numa..."

# ------------------------------------------------------------------------------
# Config file provisioning
# ------------------------------------------------------------------------------
config_source=$(bashio::config 'config_source' 'default')

if [ "${config_source}" = "file" ]; then
    if ! bashio::fs.file_exists /config/numa.toml; then
        bashio::log.fatal "config_source is set to 'file' but /config/numa.toml does not exist."
        bashio::log.fatal "Create the file or change config_source to 'default' to auto-generate it."
        exit 1
    fi
    bashio::log.info "config_source=file: using existing /config/numa.toml"
else
    bashio::log.info "Generating /config/numa.toml from add-on options..."

    # --- Read all config values ---
    filter_aaaa=$(bashio::config 'filter_aaaa' 'false')
    allow_from=$(jq -c '.allow_from // []' /data/options.json)
    rebind_protect=$(bashio::config 'rebind_protect' 'false')
    rebind_allowlist=$(jq -c '.rebind_allowlist // []' /data/options.json)
    rebind_private_ranges=$(jq -c '.rebind_private_ranges // []' /data/options.json)

    upstream_mode=$(bashio::config 'upstream_mode' 'forward')
    upstream_addresses=$(jq -c '.upstream_addresses // ["https://9.9.9.9/dns-query","https://1.1.1.1/dns-query"]' /data/options.json)
    upstream_fallback=$(jq -c '.upstream_fallback // ["9.9.9.9","149.112.112.112"]' /data/options.json)
    upstream_timeout_ms=$(bashio::config 'upstream_timeout_ms' '800')
    upstream_hedge_ms=$(bashio::config 'upstream_hedge_ms' '50')

    blocking_enabled=$(bashio::config 'blocking_enabled' 'true')
    blocking_refresh_hours=$(bashio::config 'blocking_refresh_hours' '6')
    blocking_lists=$(jq -c '.blocking_lists // ["https://cdn.jsdelivr.net/gh/hagezi/dns-blocklists@latest/hosts/pro.txt"]' /data/options.json)
    blocking_allowlist=$(jq -c '.blocking_allowlist // []' /data/options.json)

    cache_max_entries=$(bashio::config 'cache_max_entries' '100000')
    cache_min_ttl=$(bashio::config 'cache_min_ttl' '60')
    cache_max_ttl=$(bashio::config 'cache_max_ttl' '86400')
    cache_warm=$(jq -c '.cache_warm // ["home-assistant.io","version.home-assistant.io","update.home-assistant.io","cdn.jsdelivr.net"]' /data/options.json)

    proxy_enabled=$(bashio::config 'proxy_enabled' 'false')
    proxy_port=$(bashio::config 'proxy_port' '80')
    proxy_tls_port=$(bashio::config 'proxy_tls_port' '443')
    proxy_tld=$(bashio::config 'proxy_tld' 'numa')
    proxy_bind_addr=$(bashio::config 'proxy_bind_addr' '127.0.0.1')

    dot_enabled=$(bashio::config 'dot_enabled' 'true')
    dot_port=$(bashio::config 'dot_port' '853')
    dot_cert_path=$(bashio::config 'dot_cert_path' '')
    dot_key_path=$(bashio::config 'dot_key_path' '')

    dnssec_enabled=$(bashio::config 'dnssec_enabled' 'false')
    dnssec_strict=$(bashio::config 'dnssec_strict' 'false')

    lan_enabled=$(bashio::config 'lan_enabled' 'false')
    lan_broadcast_interval_secs=$(bashio::config 'lan_broadcast_interval_secs' '30')
    lan_peer_timeout_secs=$(bashio::config 'lan_peer_timeout_secs' '90')

    mobile_enabled=$(bashio::config 'mobile_enabled' 'true')
    mobile_port=$(bashio::config 'mobile_port' '8765')

    # Write to a temp file; atomic move at the end prevents a partial config.
    NUMA_CONFIG_TMP=$(mktemp)

    # --------------------------------------------------------------------------
    # [server]
    # bind_addr, api_port, api_bind_addr, data_dir are fixed for the HA add-on.
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF
# Generated by the Numa add-on — change options in the HA UI.
# Set config_source=file to manage this file manually instead.

[server]
bind_addr     = "0.0.0.0:53"
api_port      = 5381
api_bind_addr = "127.0.0.1"
data_dir      = "/data/numa"
filter_aaaa   = ${filter_aaaa}
allow_from    = ${allow_from}

# DNS rebinding protection is opt-in; local zones, overrides and .numa answers
# are exempt upstream. Empty private ranges use Numa's built-in defaults.
rebind_protect        = ${rebind_protect}
rebind_allowlist      = ${rebind_allowlist}
rebind_private_ranges = ${rebind_private_ranges}
EOF

    # --------------------------------------------------------------------------
    # [upstream]
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF

[upstream]
mode       = "${upstream_mode}"
EOF

    case "${upstream_mode}" in
      forward)
        cat >> "${NUMA_CONFIG_TMP}" << EOF
address    = ${upstream_addresses}
fallback   = ${upstream_fallback}
timeout_ms = ${upstream_timeout_ms}
hedge_ms   = ${upstream_hedge_ms}
EOF
        ;;
      recursive)
        cat >> "${NUMA_CONFIG_TMP}" << EOF
fallback   = ${upstream_fallback}
timeout_ms = ${upstream_timeout_ms}
hedge_ms   = ${upstream_hedge_ms}
EOF
        ;;
      odoh)
        odoh_relay=$(bashio::config 'upstream_odoh_relay' 'https://odoh-relay.numa.rs/relay')
        odoh_target=$(bashio::config 'upstream_odoh_target' 'https://odoh.cloudflare-dns.com/dns-query')
        odoh_relay_ip=$(bashio::config 'upstream_odoh_relay_ip' '')
        odoh_target_ip=$(bashio::config 'upstream_odoh_target_ip' '')
        odoh_strict=$(bashio::config 'upstream_odoh_strict' 'true')
        cat >> "${NUMA_CONFIG_TMP}" << EOF
relay      = "${odoh_relay}"
target     = "${odoh_target}"
strict     = ${odoh_strict}
fallback   = ${upstream_fallback}
EOF
        [ -n "${odoh_relay_ip}" ]  && [ "${odoh_relay_ip}"  != "null" ] && printf 'relay_ip   = "%s"\n' "${odoh_relay_ip}"  >> "${NUMA_CONFIG_TMP}"
        [ -n "${odoh_target_ip}" ] && [ "${odoh_target_ip}" != "null" ] && printf 'target_ip  = "%s"\n' "${odoh_target_ip}" >> "${NUMA_CONFIG_TMP}"
        ;;
    esac

    # --------------------------------------------------------------------------
    # [[forwarding]]
    # The local.hass.io rule is always injected first; user rules follow.
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << 'EOF'

# HA Supervisor internal domains — always active.
[[forwarding]]
suffix   = "local.hass.io"
upstream = "172.30.32.3"
EOF

    forwarding_count=$(jq '.forwarding_rules | length' /data/options.json)
    for i in $(seq 0 $((forwarding_count - 1))); do
        fw_suffix=$(bashio::config "forwarding_rules[${i}].suffix")
        fw_upstream=$(bashio::config "forwarding_rules[${i}].upstream")
        cat >> "${NUMA_CONFIG_TMP}" << EOF

[[forwarding]]
suffix   = "${fw_suffix}"
upstream = "${fw_upstream}"
EOF
    done

    # --------------------------------------------------------------------------
    # [blocking]
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF

[blocking]
enabled       = ${blocking_enabled}
refresh_hours = ${blocking_refresh_hours}
lists         = ${blocking_lists}
EOF
    if [ "$(printf '%s' "${blocking_allowlist}" | jq -r 'length')" -gt 0 ]; then
        printf 'allowlist     = %s\n' "${blocking_allowlist}" >> "${NUMA_CONFIG_TMP}"
    fi

    # --------------------------------------------------------------------------
    # [cache]
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF

[cache]
max_entries = ${cache_max_entries}
min_ttl     = ${cache_min_ttl}
max_ttl     = ${cache_max_ttl}
warm        = ${cache_warm}
EOF

    # --------------------------------------------------------------------------
    # [proxy] + [[services]]
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF

[proxy]
enabled   = ${proxy_enabled}
port      = ${proxy_port}
tls_port  = ${proxy_tls_port}
tld       = "${proxy_tld}"
bind_addr = "${proxy_bind_addr}"
EOF

    services_count=$(jq '.services | length' /data/options.json)
    for i in $(seq 0 $((services_count - 1))); do
        svc_name=$(bashio::config "services[${i}].name")
        svc_port=$(bashio::config "services[${i}].target_port")
        cat >> "${NUMA_CONFIG_TMP}" << EOF

[[services]]
name        = "${svc_name}"
target_port = ${svc_port}
EOF
    done

    # --------------------------------------------------------------------------
    # [[zones]]
    # --------------------------------------------------------------------------
    zones_count=$(jq '.zones | length' /data/options.json)
    for i in $(seq 0 $((zones_count - 1))); do
        zone_domain=$(bashio::config "zones[${i}].domain")
        zone_type=$(bashio::config "zones[${i}].record_type")
        zone_value=$(bashio::config "zones[${i}].value")
        zone_ttl=$(bashio::config "zones[${i}].ttl" '300')
        cat >> "${NUMA_CONFIG_TMP}" << EOF

[[zones]]
domain      = "${zone_domain}"
record_type = "${zone_type}"
value       = "${zone_value}"
ttl         = ${zone_ttl}
EOF
    done

    # --------------------------------------------------------------------------
    # [dot]
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF

[dot]
enabled = ${dot_enabled}
port    = ${dot_port}
EOF
    [ -n "${dot_cert_path}" ] && [ "${dot_cert_path}" != "null" ] && printf 'cert_path = "%s"\n' "${dot_cert_path}" >> "${NUMA_CONFIG_TMP}"
    [ -n "${dot_key_path}" ]  && [ "${dot_key_path}"  != "null" ] && printf 'key_path  = "%s"\n' "${dot_key_path}"  >> "${NUMA_CONFIG_TMP}"

    # --------------------------------------------------------------------------
    # [dnssec]
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF

[dnssec]
enabled = ${dnssec_enabled}
strict  = ${dnssec_strict}
EOF

    # --------------------------------------------------------------------------
    # [lan]
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF

[lan]
enabled                 = ${lan_enabled}
broadcast_interval_secs = ${lan_broadcast_interval_secs}
peer_timeout_secs       = ${lan_peer_timeout_secs}
EOF

    # --------------------------------------------------------------------------
    # [mobile]
    # --------------------------------------------------------------------------
    cat >> "${NUMA_CONFIG_TMP}" << EOF

[mobile]
enabled = ${mobile_enabled}
port    = ${mobile_port}
EOF

    mv "${NUMA_CONFIG_TMP}" /config/numa.toml
    bashio::log.info "numa.toml generated successfully."
fi

bashio::log.info "Config : /config/numa.toml"
bashio::log.info "Binary : $(numa version 2>&1 || true)"

# ------------------------------------------------------------------------------
# Network readiness check (brief, non-blocking)
#
# Probe Cloudflare DoH by IP (1.1.1.1:443) — no DNS lookup needed, consistent
# with the primary upstream in the default config (https://1.1.1.1/dns-query).
# Gives the blocklist downloader the best chance of succeeding on first boot.
# Capped at 3 attempts × 2 s = ~10 s worst case.
# On failure Numa starts immediately; the blocklist will retry with the
# built-in backoff (Numa v0.14.1, PR #125).
# ------------------------------------------------------------------------------
declare _net_ready=false
for _attempt in 1 2 3; do
    if curl --silent --max-time 2 --connect-timeout 2 \
        --fail \
        --header "Accept: application/dns-json" \
        --output /dev/null \
        "https://1.1.1.1/dns-query?name=dns.quad9.net&type=A" 2>/dev/null; then
        _net_ready=true
        bashio::log.debug "Outbound network ready (attempt ${_attempt}/3)"
        break
    fi
    bashio::log.debug "Network not ready yet (attempt ${_attempt}/3)..."
    if [ "${_attempt}" -lt 3 ]; then sleep 2; fi
done

if [ "${_net_ready}" != "true" ]; then
    bashio::log.warning "Outbound network not confirmed — proceeding anyway; blocklist will retry with backoff."
fi
